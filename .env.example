# ─────────────────────────────────────────────────────────────────
# Unkov — Environment Variables
#
# Copy to .env:   cp .env.example .env
#
# WHAT YOU ACTUALLY NEED:
#   Nothing — the app runs on demo data with zero configuration.
#   Add Supabase keys only when you want real login.
#   Add API URL only when you want live scan data.
#
# WHAT NEVER GOES HERE:
#   Supabase service role key → set in Vercel dashboard only
#   Investor salt / admin key → set in Vercel dashboard only
# ─────────────────────────────────────────────────────────────────

# ── Auth (optional — app works without this) ──────────────────────
# Get from: supabase.com → project → Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# ── Live dashboard data (optional — demo data works without this) ─
# Set to your engine API URL after running: npm run deploy
# Local dev: http://localhost:4000
VITE_API_URL=
VITE_DASHBOARD_API_KEY=
